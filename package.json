{
  "name": "centuria",
  "private": true,
  "version": "0.43.0",
  "description": "Centuria",
  "author": "aslater100",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "sim": "tsx src/sim/headless.ts",
    "sim:town": "tsx src/sim/town-headless.ts",
    "sim:macro": "tsx src/sim/macro-headless.ts",
    "hf-sprites": "tsx scripts/hf-sprites.ts",
    "app": "npm run build && electron .",
    "app:dist": "npm run build && npx electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.centuria.app",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "aslater100",
      "repo": "Centuria",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
